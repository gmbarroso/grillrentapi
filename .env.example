# App
NODE_ENV=development
PORT=3000
TZ=UTC

# Auth
JWT_SECRET=replace-with-a-strong-secret
INTERNAL_SERVICE_TOKEN=replace-with-a-strong-internal-token
API_CORS_ALLOWED_ORIGINS=https://your-bff.example.com,https://your-frontend.example.com
CORS_ALLOWED_ORIGINS=https://your-bff.example.com,https://your-frontend.example.com
# Legacy compatibility key (still accepted by src/main.ts)
CORS_ORIGINS=https://your-bff.example.com,https://your-frontend.example.com

# Primary DB config used by AppModule
DATABASE_URL=postgres://postgres:postgres@localhost:5432/grillrentapi

# Optional compatibility keys used by local scripts/tools (data-source/ormconfig)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=grillrentapi

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=grillrentapi

# WhatsApp Evolution integration (consumed by grillrentapi)
WHATSAPP_EVOLUTION_BASE_URL=https://your-evolution-url.example.com
WHATSAPP_EVOLUTION_INSTANCE=your-instance-name
WHATSAPP_EVOLUTION_API_KEY=replace-with-your-evolution-api-key
WHATSAPP_GROUP_JID_BY_ORG={"your-organization-uuid":"120363xxxxxxxxxxxx@g.us"}
WHATSAPP_SEND_MAX_ATTEMPTS=3
WHATSAPP_SEND_BASE_BACKOFF_MS=250
WHATSAPP_SEND_TIMEOUT_MS=8000

# Inbound email reply threading
CONTACT_EMAIL_INBOUND_SECRET=replace_with_strong_random_secret
CONTACT_EMAIL_REPLY_TOKEN_SECRET=replace_with_strong_random_secret
CONTACT_EMAIL_REPLY_TOKEN_TTL_HOURS=720
# Required mailbox base address used for VERP-style reply-to, e.g. faleconosco@example.com
CONTACT_EMAIL_REPLY_BASE_ADDRESS=faleconosco@example.com
