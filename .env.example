# App
NODE_ENV=development
PORT=3000

# Auth
JWT_SECRET=replace-with-a-strong-secret
INTERNAL_SERVICE_TOKEN=replace-with-a-strong-internal-token
API_CORS_ALLOWED_ORIGINS=https://your-bff.example.com,https://your-frontend.example.com
CORS_ALLOWED_ORIGINS=https://your-bff.example.com,https://your-frontend.example.com
# Legacy compatibility key (still accepted by src/main.ts)
CORS_ORIGINS=https://your-bff.example.com,https://your-frontend.example.com

# Primary DB config used by AppModule
DATABASE_URL=postgres://postgres:postgres@localhost:5432/grillrentapi

# Optional compatibility keys used by local scripts/tools (data-source/ormconfig)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=grillrentapi

